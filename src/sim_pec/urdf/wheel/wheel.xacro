<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
    <xacro:include filename="$(find sim_pec)/urdf/common_inertia.xacro" />
        <xacro:macro name="wheel_xacro" params="wheel_name xyz">
            <link name="${wheel_name}_wheel_link">
                <visual>
                    <!-- 自身绕x轴旋转90度,即对应roll -->
                    <origin xyz="0 0 0" rpy="1.57079 0 0" />
                    <!-- 半径8.5cm，轮宽5cm -->
                    <geometry>
                        <cylinder length="0.05" radius="0.085" />
                    </geometry>
                    <material name="black">
                        <color rgba="0.0 0.0 0.0 0.9"/>
                    </material>
                </visual>
                <collision>
                    <!-- 自身绕x轴旋转90度,即对应roll -->
                    <origin xyz="0 0 0" rpy="1.57079 0 0" />
                    <!-- 半径8.5cm，轮宽5cm -->
                    <geometry>
                        <cylinder length="0.05" radius="0.085" />
                    </geometry>
                    <material name="black">
                        <color rgba="0.0 0.0 0.0 0.9"/>
                    </material>
                </collision>
                <xacro:cylinder_inertia m="2" r="0.085" h="0.05" rpy="1.57079 0 0"/>
            </link>

            <!-- 轮子与base_link连接 -->
            <!-- 绕y轴旋转 -->
            <joint name="${wheel_name}_wheel_joint" type="continuous">
                <parent link="base_link" />
                <child link="${wheel_name}_wheel_link" />
                <origin xyz="${xyz}" />
                <axis xyz="0 1 0" />
                <limit effort="10" velocity="100"/>
            </joint>

        </xacro:macro>
</robot>